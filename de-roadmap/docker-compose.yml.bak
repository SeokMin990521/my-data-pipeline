
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
  data-network:
    driver: bridge

services:
  # 1~2일차: 메인 서비스용 DB
  mariadb:
    image: mariadb:latest
    container_name: my-mariadb
    ports:
      - "3306:3306"
    environment:
      MARIADB_ROOT_PASSWORD: "1234"
    volumes:
      - ./mariadb_data:/var/lib/mysql
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network

  # 8일차: 분석용 데이터 웨어하우스 DB
  postgres:
    image: postgres:latest
    container_name: my-postgres
    ports:
      - "5432:5432"
    environment:
      POSTGRES_PASSWORD: "1234"
    volumes:
      - ./postgres_data:/var/lib/postgresql
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network

  # 7일차: 웹 DB 관리 툴 (MariaDB, Postgres 둘 다 접속 가능)
  adminer:
    image: adminer:latest
    container_name: my-adminer
    ports:
      - "8089:8080"
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network

  # 9일차: 분산 메시지 큐 (Zookeeper & Kafka)
  zookeeper:
    image: confluentinc/cp-zookeeper:7.5.0
    container_name: my-zookeeper
    environment:
      ZOOKEEPER_CLIENT_PORT: 2181
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network

  # 7~8일차: 실시간 데이터 시각화 및 알람 관제탑
  grafana:
    image: grafana/grafana:latest
    container_name: my-grafana
    ports:
      - "3000:3000"
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network

  # 3~5, 9~10일차: 핵심 비즈니스 로직을 수행할 파이썬 데이터 파이프라인 애플리케이션
  data-app:
    build: ./app
    container_name: my-data-app
    restart: always
    depends_on:
      - mariadb
      - postgres
      - kafka
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network

  kafka:
    image: confluentinc/cp-kafka:7.5.0
    container_name: my-kafka
    depends_on:
      - zookeeper
    ports:
      - "9092:9092"
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      # ⭐️ 교안 2단계에 적힌 외부 호스트용(127.0.0.1:9092) 리스너 세팅입니다!
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:29092,PLAINTEXT_HOST://127.0.0.1:9092
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network

  schema-registry:
    image: confluentinc/cp-schema-registry:7.5.0
    container_name: my-schema-registry
    depends_on:
      - zookeeper
      - kafka
    ports:
      - "8081:8081"
    environment:
      SCHEMA_REGISTRY_HOST_NAME: schema-registry
      SCHEMA_REGISTRY_KAFKASTORE_BOOTSTRAP_SERVERS: kafka:29092
      SCHEMA_REGISTRY_LISTENERS: http://0.0.0.0:8081
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network
# 12일차 추가: 데이터 레이크용 로컬 오브젝트 스토리지 (S3 호환)
  minio:
    image: minio/minio:latest
    container_name: my-minio
    ports:
      - "9000:9000"       # 🌟 외부 Python App이나 Spark가 S3 API로 통신할 포트
      - "9001:9001"       # 🌟 웹 브라우저 관리 콘솔 UI용 포트
    environment:
      MINIO_ROOT_USER: "admin"
      MINIO_ROOT_PASSWORD: "password123"
    volumes:
      - ./minio_data:/data   # 데이터 영속성을 위한 호스트 볼륨 맵핑
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network
    command: server /data --console-address ":9001"

  # [11일차 최종형] 관제탑 설정 (Adminer 포트와 충돌을 막기 위해 8080 고정)
  kafka-ui:
    image: provectuslabs/kafka-ui:latest
    container_name: my-kafka-ui
    ports:
      - "8080:8080" 
    environment:
      KAFKA_CLUSTERS_0_NAME: local
      KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS: kafka:29092
      KAFKA_CLUSTERS_0_SCHEMAREGISTRY: http://schema-registry:8081
    
  spark:
    image: apache/spark:3.5.0
    container_name: my-spark
    user: root
    entrypoint: ["/bin/bash", "-c", "tail -f /dev/null"]
    volumes:
      - .:/opt/spark/app
    networks:
      - data-network

networks:
      - data-network
# 14일차 추가: 대용량 분산 연산 엔진 (Bitnami Spark)
